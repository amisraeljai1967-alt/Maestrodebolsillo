    {
      "id": 1,
      "pregunta": "¿Cuál de los siguientes números es irracional?",
      "options": {
        "A": "√2",
        "B": "√9",
        "C": "3/4",
        "D": "0.5"
      },
      "correctAnswer": "A",
      "explanation": "√2 es irracional porque no puede expresarse como fracción de enteros. Su decimal es infinito y no periódico. √9 = 3 es racional, al igual que 3/4 y 0.5.",
      "subject": "Matemáticas",
      "topic": "Números reales",
      "level": "Básico"
    },
    {
      "id": 2,
      "pregunta": "¿Qué tipo de número es π (pi)?",
